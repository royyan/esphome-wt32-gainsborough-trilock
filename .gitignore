# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
/secrets.yaml

# Local logs and generated artifacts
*.log
.DS_Store
__pycache__/
*.py[cod]

# Local editor/agent metadata
/.antigravitycli/

# Local reverse-engineering scratch scripts
/tools/check_log.js
/tools/decrypt.js
/tools/get-all-nonces.js
/tools/freestyle-app-config.json
